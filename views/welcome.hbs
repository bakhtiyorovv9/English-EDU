{{!< layout}}
<div class="shell split">
  {{> hero}}
  <main class="pane content">
    <div class="content-inner">
      <div class="bar r r1">
        <span class="crumb">Englyx / Xush kelibsiz</span>
        <div class="haveacc">
          <span>Akkauntim bor</span>
          <a class="btn ghost" href="/login">Kirish
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="center">
        <div class="eyebrow r r2">Boshlash</div>
        <h2 class="h-title r r3" style="margin-top:14px">3 ta savol bilan <em>boshlaymiz</em></h2>
        <p class="h-desc r r3">Daraja, maqsad va kunlik vaqtni belgilang &mdash; biz sizga mos rejani tayyorlaymiz. Bepul, 2 daqiqa.</p>

        <div class="steps">
          <a class="scard lead r r4" href="/onboarding/level">
            <div class="snum">1</div>
            <div class="txt"><h4>Darajangizni tanlang</h4><p>A1 dan C2 gacha &middot; yoki tezkor test</p></div>
            <span class="btn dark">Boshlash
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
          <a class="scard r r5" href="/onboarding/level">
            <div class="snum">2</div>
            <div class="txt"><h4>Maqsadingizni belgilang</h4><p>IELTS, sayohat, ish yoki shunchaki&hellip;</p></div>
            <span class="chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></span>
          </a>
          <a class="scard r r6" href="/onboarding/level">
            <div class="snum">3</div>
            <div class="txt"><h4>Akkaunt yarating</h4><p>Streak va progressni saqlash uchun</p></div>
            <span class="chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></span>
          </a>
        </div>
      </div>

      <div class="foot">
        <div class="meta">&copy; <b>ENGLYX 2026</b> &middot; MAXFIYLIK &middot; SHARTLAR</div>
        <div class="lang"><b>UZ</b> &middot; RU &middot; EN</div>
      </div>
    </div>
  </main>
</div>
