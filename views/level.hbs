{{!< layout}}
<div class="shell split">
  <main class="pane content first fade">
    {{> mstrip mlabel="Qadam 2 / 4"}}
    <form class="content-inner" method="get" action="/onboarding/goal">
      <input type="hidden" name="level" value="{{level}}" data-level-input />

      <div class="stephead r r1">
        <a class="backbtn" href="/" aria-label="Orqaga">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </a>
        <div class="stepmeta">
          <span class="q">Qadam {{step}} / {{total}}</span>
          <div class="dashes">
            <span class="dash on"></span><span class="dash on"></span><span class="dash"></span><span class="dash"></span>
          </div>
        </div>
      </div>

      <div class="center">
        <h2 class="h-title r r2">Darajangizni <em>tanlang</em></h2>
        <p class="h-desc r r2">CEFR shkalasi bo&lsquo;yicha. Aniq bilmasangiz <b>B1</b> ni tanlang yoki tezkor testdan o&lsquo;ting.</p>

        <div class="grid2">
          {{#each levels}}
          <button type="button" class="lvl r r3{{#if selected}} on{{/if}}" data-level="{{this.id}}">
            <div class="lbadge">{{this.id}}</div>
            <div class="li"><h4>{{this.t}}</h4><q>&ldquo;{{this.q}}&rdquo;</q></div>
            <div class="radio">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
          </button>
          {{/each}}
        </div>

        <div class="unknown r r6">
          <div class="lbadge" style="background:transparent;border:1px dashed var(--line)">?</div>
          <div class="li"><h4>Bilmayman</h4><p>3 daqiqali tezkor test bilan aniqlaymiz</p></div>
          <a class="btn ghost" href="/onboarding/goal?level=B1">Testni boshlash
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="navrow">
        <a class="btn plain" href="/">&larr; Orqaga</a>
        <button type="submit" class="btn dark lg">Davom etish
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </div>

      <div class="foot bare">
        <div class="meta">&copy; <b>ENGLYX 2026</b> &middot; MAXFIYLIK &middot; SHARTLAR</div>
        <div class="lang"><b>UZ</b> &middot; RU &middot; EN</div>
      </div>
    </form>
  </main>
  {{> hero step=true}}
</div>
